# Public build-time env (baked into the static build by Vite).
# Copy to `.env.production` / `.env.staging` and set per environment.

# Canonical site URL — used for SEO canonicals, OG image URLs, sitemap.
PUBLIC_SITE_URL=https://chrishemmings.co.uk

# GitHub repo (owner/name) the /publish page squash-merges staging→main on.
# Required for /publish to work on the staging build.
PUBLIC_GITHUB_REPO=den-frie-vilje/chrishemmings.co.uk
